# Deploy-script credentials for com/*.bat -- a SEPARATE, unrelated
# concern from this project's own application `.env` (Node config, DB
# connection, JWT secret, etc. -- see docs/setup.md and `.env` itself).
# Copy this file to `.env.deploy` and fill in real values -- gitignored,
# never committed. Deliberately named ".env.deploy", not ".env", so it
# can never collide with or be confused for the app's own config file.
#
# Same migration as auth-data/finan-data/animecream-data/module-data/
# animecream-react/finan-react -- see auth-data's (archived)
# docs/credential-migration-runbook.md for the full story.
#
# Variable names intentionally keep the old "keys/<name>.txt" suffix,
# so com/db-sync-FTP-both.bat keeps working unchanged -- only where
# the values are read from changes.

FTPUsername.txt=
FTPPss.txt=
FTPserver.txt=
FTPFolder.txt=
LocalPath.txt=
Link_restart_node.txt=
